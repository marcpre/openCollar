{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "open collar",
  "version": "0.1.0",
  "identifier": "com.opencollar.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "open collar",
        "width": 1600,
        "height": 980,
        "minWidth": 1280,
        "minHeight": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
